{
  "manifest_version": 3,
  "name": "UnmarkAI",
  "version": "1.0.0",
  "description": "Cleanly remove the ✦ badge from images generated by Gemini and AI Studio. All processing happens on your device.",
  "permissions": [
    "storage",
    "scripting",
    "contextMenus",
    "downloads",
    "offscreen"
  ],
  "host_permissions": [
    "https://gemini.google.com/*",
    "https://aistudio.google.com/*",
    "https://*.googleusercontent.com/*",
    "https://github.com/*",
    "https://objects.githubusercontent.com/*",
    "https://release-assets.githubusercontent.com/*"
  ],
  "content_security_policy": {
    "extension_pages": "script-src 'self' 'wasm-unsafe-eval'; object-src 'self'"
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "https://gemini.google.com/*",
        "https://aistudio.google.com/*"
      ],
      "js": ["main-world.js"],
      "run_at": "document_start",
      "world": "MAIN"
    },
    {
      "matches": [
        "https://gemini.google.com/*",
        "https://aistudio.google.com/*"
      ],
      "js": ["content.js"],
      "run_at": "document_start",
      "world": "ISOLATED"
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "UnmarkAI — Clean Gemini images",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "commands": {
    "_execute_action": {
      "suggested_key": { "default": "Alt+U" },
      "description": "Open UnmarkAI"
    }
  },
  "web_accessible_resources": []
}